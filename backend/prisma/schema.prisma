datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   // "USER" or "ADMIN"
  createdAt DateTime @default(now())
}

model Vehicle {
  id        String   @id @default(uuid())
  make      String
  model     String
  category  String
  price     Float
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id           String   @id @default(uuid())
  userEmail    String
  vehicleMake  String
  vehicleModel String
  pricePaid    Float
  purchasedAt  DateTime @default(now())
}
